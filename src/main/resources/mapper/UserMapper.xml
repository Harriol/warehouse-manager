<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pn.warehouse_manager.mapper.UserMapper">

    <!--
        根据账号查询用户信息的方法
        User findUserByCode(String userCode);
    -->
    <select id="findUserByCode" resultType="com.pn.warehouse_manager.entity.User">
        select * from user_info where user_code = #{userCode} and is_delete = 0;
    </select>


</mapper>